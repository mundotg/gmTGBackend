# -----------------------------
# ⚙️ Aplicação
# -----------------------------
APP_NAME=GeradorDadosInteligente
APP_ENV=development
APP_LOCALE=pt_PT

# -----------------------------
# 🌐 CORS e Cookies
# -----------------------------
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=localhost

# -----------------------------
# 💾 Sistema de Cache
# -----------------------------
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=100
CACHE_CLEANUP_INTERVAL=3600
CACHE_CLEANUP_PROBABILITY=0.01
CACHE_MAX_OLD_FILES_REMOVE=10
CACHE_DISABLE_FLAG=False
CACHE_DIR_NAME=cache
CACHE_PICKLE_PROTOCOL=4
CACHE_LOG_HITS=False
CACHE_LOG_MISSES=False

# -----------------------------
# 🧩 Cache Binário (offsets, etc.)
# -----------------------------
CACHE_BINARIO_ENABLED=True
CACHE_BINARIO_FILE=offset_cache.bin
CACHE_BINARIO_AUTO_SAVE=True
CACHE_BINARIO_SAVE_INTERVAL=60
CACHE_BINARIO_COMPRESSION=False

# -----------------------------
# 📊 Log
# -----------------------------
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# -----------------------------
# ⚡ Performance
# -----------------------------
MAX_WORKERS=4
BATCH_SIZE=1000
REQUEST_TIMEOUT=30

# -----------------------------
# 🤖 Faker e Gerador
# -----------------------------
FAKER_LOCALE=pt_PT
FAKER_SEED=42
GENERATOR_DEFAULT_LOCALE=pt_PT
GENERATOR_MAX_RETRIES=3
GENERATOR_UNIQUE_RETRIES=100
GENERATOR_NULL_PROBABILITY=0.05


FORCE_DB_RESET=true
# -----------------------------
# 🧪 Testes
# -----------------------------
TEST_MODE=False
TEST_SEED=123
TEST_MAX_ROWS=10000

# -----------------------------
# 🌐 API e Monitoramento
# -----------------------------
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3
MONITORING_ENABLED=False
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# -----------------------------
# 🧠 IA & LLMs
# -----------------------------
DISABLE_MODEL_SOURCE_CHECK=True

# ================================
# Gemini API
# ================================
GEMINI_API_KEY=sua_api_key_do_google_aqui
MODEL_NAME=gemini-2.5-flash
GEMINI_TEMPERATURE="0.7"
GEMINI_MAX_TOKENS="8192"
GEMINI_MAX_RETRIES="3"
GEMINI_SYSTEM_PROMPT="És um especialista em Base de dados, Ciência de dados e Engenharia de software. Responde de forma clara, prática e didática. Se não souberes, diz que não sabes."

# ================================
# DeepSeek API
