# =========================
# 🔐 API KEYS (NUNCA EXPOR)
# =========================

# Chave principal (server-side apenas)
GOOGLE_API_KEY=your_secure_api_key_here

# Ambiente
NODE_ENV=production

# =========================
# 🌐 RESTRIÇÕES (DOCUMENTAÇÃO)
# =========================

# NÃO USE:
# ❌ Query params (?api_key=...)
# ✔️ Use headers:
# x-goog-api-key: <API_KEY>

# =========================
# 🧠 SEGURANÇA
# =========================

# Nunca expor no frontend
EXPOSE_API_KEY=false

# Uso apenas no backend
API_KEY_SERVER_ONLY=true

# Rotação de chave (dias)
API_KEY_ROTATION_DAYS=30

# =========================
# 📊 MONITORAMENTO
# =========================

ENABLE_API_MONITORING=true
ENABLE_LOGGING=true

# =========================
# 👥 CONTROLE DE ACESSO
# =========================

# Chaves separadas por serviço
API_KEY_SERVICE_AUTH=auth_key_here
API_KEY_SERVICE_DATA=data_key_here

# =========================
# 🚨 SEGURANÇA AVANÇADA
# =========================

# Limitar uso por IP (configurar no provider)
API_KEY_RESTRICT_IP=true

# Limitar por domínio (se aplicável)
API_KEY_RESTRICT_DOMAIN=true

# =========================
# ⚠️ ALERTAS
# =========================

ALERT_ON_ABUSE=true
ALERT_EMAIL=admin@seusite.com