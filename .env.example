# ================================
# 🌍 AMBIENTE GERAL
# ================================
ENV=dev
HOST=0.0.0.0
PORT=8000
DEBUG=true
FLAG_FILE="init_done.bin"

# ================================
# 🗄️ BANCO DE DADOS
# ================================
# Exemplo com PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# Exemplo usado pelo Alembic (para migrações)
DATABASE_URL_ALEMBIC=postgresql+psycopg2://usuario:senha@localhost:5432/nome_do_banco

# Parâmetros individuais (opcional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nome_do_banco
DB_USER=usuario
DB_PASSWORD=senha
DB_SCHEMA=public

# ================================
# 🔐 AUTENTICAÇÃO E SEGURANÇA
# ================================
SECRET_KEY=sua_chave_jwt_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

ENCRYPTION_KEY=sua_chave_de_criptografia_32_chars

# ================================
# 🌐 CORS E COOKIES
# ================================
BACKEND_CORS_ORIGINS=http://localhost:3000

# true em produção (HTTPS)
COOKIE_SECURE=false

# none → HTTPS cross-origin / lax → local
COOKIE_SAMESITE=lax

COOKIE_DOMAIN=localhost

# ================================
# ⚙️ CONFIGURAÇÕES DA APLICAÇÃO
# ================================
APP_NAME=GeradorDadosInteligente
APP_ENV=development
APP_DEBUG=True
APP_LOCALE=pt_PT

# ================================
# 🧠 CACHE
# ================================
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=100
CACHE_CLEANUP_INTERVAL=3600
CACHE_DIR_NAME=cache
CACHE_USE_GZIP=True
CACHE_GZIP_COMPRESSION_LEVEL=6

# ================================
# 🧾 LOGS
# ================================
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ================================
# ⚡ PERFORMANCE
# ================================
MAX_WORKERS=4
BATCH_SIZE=1000
REQUEST_TIMEOUT=30

# ================================
# 🎭 FAKER (GERADOR DE DADOS)
# ================================
FAKER_LOCALE=pt_PT
FAKER_SEED=42
FAKER_PROVIDERS=

# ================================
# 🧩 GERADOR DE DADOS
# ================================
GENERATOR_DEFAULT_LOCALE=pt_PT
GENERATOR_MAX_RETRIES=3
GENERATOR_UNIQUE_RETRIES=100
GENERATOR_NULL_PROBABILITY=0.05

# ================================
# 🧰 CACHE BINÁRIO
# ================================
CACHE_BINARIO_ENABLED=True
CACHE_BINARIO_FILE=offset_cache.bin
CACHE_BINARIO_AUTO_SAVE=True
CACHE_BINARIO_SAVE_INTERVAL=60
CACHE_BINARIO_COMPRESSION=False

# ================================
# 🧪 TESTES
# ================================
TEST_MODE=False
TEST_SEED=123
TEST_MAX_ROWS=10000

# ================================
# 📤 EXPORTAÇÃO
# ================================
EXPORT_FORMAT=json
EXPORT_ENCODING=utf-8
EXPORT_INCLUDE_METADATA=True

# ================================
# 🌐 API EXTERNA
# ================================
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# ================================
# 📊 MONITORAMENTO
# ================================
MONITORING_ENABLED=False
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30
# ================================
#gemini api
# ================================
GEMINI_API_KEY = xxxyxyxxyxy